<% layout('teacher/layouts/teacherBoiler') %>

<style>
.result-card{
  background:#ffffff;
  padding:32px;
  border-radius:24px;
  box-shadow:0 25px 60px rgba(0,0,0,.12);
  max-width:900px;
  margin:auto;
}

.result-card h3{
  font-weight:900;
  margin-bottom:10px;
}

.sub-title{
  color:#64748b;
  margin-bottom:25px;
}

.subject-row{
  display:grid;
  grid-template-columns:2fr 1fr 1fr auto;
  gap:14px;
  margin-bottom:12px;
}

.calc-box{
  background:linear-gradient(135deg,#eef2ff,#f8fafc);
  padding:18px;
  border-radius:16px;
  font-weight:700;
  display:flex;
  justify-content:space-between;
  flex-wrap:wrap;
}

.calc-box span{
  color:#1e40af;
}

.success-alert{
  background:#dcfce7;
  color:#166534;
  padding:14px;
  border-radius:14px;
  font-weight:700;
  margin-bottom:20px;
  display:none;
}
</style>

<div class="result-card">

  <div class="success-alert" id="successMsg">
    ✅ Result saved successfully!
  </div>

  <h3>
    <i class="bi bi-bar-chart-fill"></i> Add Student Result
  </h3>
  <p class="sub-title">
    Enter subject-wise marks — totals & CGPA are calculated automatically
  </p>

  <form method="POST" action="/admin/teacher/results/add" id="resultForm">

    <!-- STUDENT -->
    <div class="mb-3">
      <label class="fw-semibold">Student</label>
      <select name="studentId" class="form-select" required>
        <% students.forEach(s => { %>
          <option value="<%= s.studentId %>">
            <%= s.studentId %> – <%= s.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <!-- SEMESTER -->
    <div class="mb-4">
      <label class="fw-semibold">Semester</label>
      <select name="semester" class="form-select" required>
        <% for(let i=1;i<=8;i++){ %>
          <option value="<%= i %>"><%= i %></option>
        <% } %>
      </select>
    </div>

    <!-- SUBJECTS -->
    <h5 class="fw-bold mb-3">Subject-wise Marks</h5>

    <div id="subjects">

      <div class="subject-row">
        <input name="subjects[0][subjectName]" class="form-control" placeholder="Subject Name" required>
        <input name="subjects[0][marks]" class="form-control marks" type="number" placeholder="Marks" required>
        <input name="subjects[0][maxMarks]" class="form-control" type="number" value="100">
        <button type="button" class="btn btn-danger remove">✖</button>
      </div>

    </div>

    <button type="button" class="btn btn-outline-primary mb-4" id="addSubject">
      + Add Subject
    </button>

    <!-- AUTO CALC -->
    <div class="calc-box mb-4">
      <div>Total: <span id="total">0</span></div>
      <div>Percentage: <span id="percent">0</span>%</div>
      <div>CGPA: <span id="cgpa">0</span></div>
    </div>

    <button class="btn btn-success w-100 py-2">
      <i class="bi bi-save-fill"></i> Save Result
    </button>

  </form>
</div>

<script>
let index = 1;
const subjects = document.getElementById("subjects");
const totalEl = document.getElementById("total");
const percentEl = document.getElementById("percent");
const cgpaEl = document.getElementById("cgpa");
const successMsg = document.getElementById("successMsg");

document.getElementById("addSubject").onclick = () => {
  subjects.insertAdjacentHTML("beforeend", `
    <div class="subject-row">
      <input name="subjects[${index}][subjectName]" class="form-control" placeholder="Subject Name" required>
      <input name="subjects[${index}][marks]" class="form-control marks" type="number" placeholder="Marks" required>
      <input name="subjects[${index}][maxMarks]" class="form-control" type="number" value="100">
      <button type="button" class="btn btn-danger remove">✖</button>
    </div>
  `);
  index++;
};

subjects.addEventListener("input", calculate);
subjects.addEventListener("click", e => {
  if(e.target.classList.contains("remove")){
    e.target.parentElement.remove();
    calculate();
  }
});

function calculate(){
  const marks = [...document.querySelectorAll(".marks")].map(i => +i.value || 0);
  const max = marks.length * 100;
  const total = marks.reduce((a,b)=>a+b,0);
  const percent = max ? (total/max)*100 : 0;
  const cgpa = percent/9.5;

  totalEl.innerText = total;
  percentEl.innerText = percent.toFixed(2);
  cgpaEl.innerText = cgpa.toFixed(2);
}

/* Show success message after redirect */
if (window.location.search.includes("success")) {
  successMsg.style.display = "block";
}
</script>
