<!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= typeof title !== "undefined" ? title : "EduVault ERP" %></title>

  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <!-- Font Awesome (Sidebar Icons) -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
  />

  <!-- ✅ Bootstrap Icons (Dashboard Cards, etc.) -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
  />

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css"/>

  <style>
    body {
      padding-top: 72px;
      background: #f4f7fc;
    }

    .sidebar {
      width: 240px;
      min-height: calc(100vh - 72px);
      background: #1e1e2d;
      color: #fff;
    }

    .sidebar .nav-link {
      color: #cfd1d4;
      border-radius: 8px;
      padding: 10px 14px;
      margin-bottom: 6px;
      font-weight: 500;
    }

    .sidebar .nav-link:hover,
    .sidebar .nav-link.active {
      background: #4e73df;
      color: #fff;
    }

    main {
      flex: 1;
    }
  </style>

</head>
<body>

  <!-- TOP NAVBAR -->
  <%- include("../includes/navbar") %>

  <div class="d-flex">

    <!-- ADMIN SIDEBAR -->
    <% if (active && active.startsWith("admin")) { %>
      <aside class="sidebar p-3">

        <h5 class="mb-4 fw-bold">Admin Panel</h5>

        <ul class="nav flex-column">

          <li class="nav-item">
            <a href="/admin/dashboard"
               class="nav-link <%= active === 'admin-dashboard' ? 'active' : '' %>">
              <i class="fa fa-home me-2"></i> Dashboard
            </a>
          </li>

          <li class="nav-item">
            <a href="/admin/teacher"
               class="nav-link <%= active === 'admin-students' ? 'active' : '' %>">
              <i class="fa fa-users me-2"></i> Manage Students
            </a>
          </li>

          <li class="nav-item">
            <a href="/admin/teacher/add"
               class="nav-link <%= active === 'admin-add-student' ? 'active' : '' %>">
              <i class="fa fa-user-plus me-2"></i> Add Student
            </a>
          </li>


          <li class="nav-item">
            <a href="/teacher/attendance"
            class="nav-link <%= active === 'admin-attendance' ? 'active' : '' %>">
            <i class="fa fa-calendar-check me-2"></i> Attendance
           </a>
</li>

<li class="nav-item">
  <a href="/admin/teacher/results"
     class="nav-link <%= active === 'admin-results' ? 'active' : '' %>">
    <i class="fa fa-chart-bar me-2"></i> Results
  </a>
</li>


         

          <li class="nav-item">
            <a href="/admin/teacher/notices"
               class="nav-link <%= active === 'admin-notices' ? 'active' : '' %>">
              <i class="fa fa-bell me-2"></i> Notices
            </a>
          </li>

        </ul>
      </aside>
    <% } %>

    <!-- MAIN CONTENT -->
    <main class="container my-4">
      <%- body %>
    </main>

  </div>

  <!-- FOOTER -->
  <footer class="text-center p-3 mt-4 text-muted">
    <small>© <%= new Date().getFullYear() %> EduVault ERP — All Rights Reserved.</small>
  </footer>

  <!-- Bootstrap JS -->
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js">
  </script>

</body>
</html>
