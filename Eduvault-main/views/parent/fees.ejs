<% layout('parent/layouts/parentBoiler') %>
<% active = "fees" %>
<% title = "Student Fees" %>

<style>
  body{background:#f5f7fb;}

  /* HEADER */
  .page-header{
    background:linear-gradient(135deg,#36b9cc,#1cc88a);
    padding:26px;
    border-radius:20px;
    color:#fff;
    margin-bottom:30px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:14px;
  }

  .student-chip{
    background:rgba(255,255,255,.2);
    padding:10px 18px;
    border-radius:30px;
    font-weight:700;
  }

  /* SUMMARY */
  .summary-card{
    background:#fff;
    border-radius:18px;
    padding:22px;
    box-shadow:0 12px 30px rgba(0,0,0,.1);
    margin-bottom:30px;
  }

  .summary-item{
    display:flex;
    justify-content:space-between;
    font-weight:800;
    font-size:18px;
    margin-bottom:10px;
  }

  .paid{color:#1cc88a;}
  .due{color:#e74a3b;}

  /* TABLE */
  .fee-card{
    background:#fff;
    border-radius:20px;
    padding:22px;
    box-shadow:0 12px 30px rgba(0,0,0,.1);
  }

  table th{
    background:#f8f9fc;
    font-weight:800;
    font-size:14px;
  }

  table td{
    font-weight:600;
    vertical-align:middle;
  }

  .pay-btn{
    background:linear-gradient(135deg,#4e73df,#224abe);
    color:#fff;
    border:none;
    padding:8px 16px;
    border-radius:12px;
    font-weight:700;
    box-shadow:0 8px 20px rgba(78,115,223,.35);
  }

  .pay-btn:hover{
    opacity:.9;
  }
</style>

<!-- HEADER -->
<div class="page-header">
  <div>
    <h3><i class="bi bi-currency-rupee"></i> Fees Overview</h3>
    <p class="mb-0 opacity-90">Manage and pay your child’s fees securely</p>
  </div>

  <div class="student-chip">
    <i class="bi bi-person-fill"></i>
    <%= student.name %> · Roll <%= student.roll %>
  </div>
</div>

<!-- SUMMARY -->
<div class="summary-card">
  <div class="summary-item">
    <span>Total Paid</span>
    <span class="paid">₹<%= totalPaid %></span>
  </div>
  <div class="summary-item">
    <span>Total Due</span>
    <span class="due">₹<%= totalDue %></span>
  </div>
</div>

<!-- FEES TABLE -->
<div class="fee-card">
  <table class="table table-hover align-middle">
    <thead>
      <tr>
        <th>Fee Type</th>
        <th>Amount</th>
        <th>Status</th>
        <th>Date</th>
        <th class="text-center">Action</th>
      </tr>
    </thead>
    <tbody>

      <% if (fees.length === 0) { %>
        <tr>
          <td colspan="5" class="text-center text-muted">
            No fee records available.
          </td>
        </tr>
      <% } %>

      <% fees.forEach(f => { %>
        <tr>
          <td><strong><%= f.title || 'Academic Fee' %></strong></td>
          <td>₹<%= f.amount %></td>
          <td>
            <span class="badge <%= f.status === 'paid' ? 'bg-success' : 'bg-danger' %>">
              <%= f.status.toUpperCase() %>
            </span>
          </td>
          <td>
            <%= f.date ? new Date(f.date).toLocaleDateString() : '-' %>
          </td>
          <td class="text-center">

            <% if (f.status !== 'paid') { %>
              <!-- PAY NOW -->
              <a href="/parent/payment/<%= f._id %>" class="pay-btn">
                <i class="bi bi-credit-card-fill"></i> Pay Now
              </a>
            <% } else { %>
              <span class="text-success fw-bold">
                <i class="bi bi-check-circle-fill"></i> Paid
              </span>
            <% } %>

          </td>
        </tr>
      <% }) %>

    </tbody>
  </table>
</div>
