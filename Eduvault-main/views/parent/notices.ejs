<% layout('parent/layouts/parentBoiler') %>
<% active = "notices" %>
<% title = "Notices" %>

<style>
  body{background:#f5f7fb;}

  /* HEADER */
  .page-header{
    background:linear-gradient(135deg,#6f42c1,#36b9cc);
    padding:26px;
    border-radius:20px;
    color:#fff;
    margin-bottom:30px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:14px;
  }

  .page-header h3{
    font-weight:900;
    margin-bottom:6px;
  }

  .student-chip{
    background:rgba(255,255,255,.2);
    padding:10px 18px;
    border-radius:30px;
    font-weight:700;
  }

  /* NOTICE CARD */
  .notice-card{
    background:#fff;
    border:none;
    border-radius:18px;
    padding:22px;
    box-shadow:0 12px 30px rgba(0,0,0,.1);
    margin-bottom:18px;
    transition:.3s ease;
  }

  .notice-card:hover{
    transform:translateY(-6px);
    box-shadow:0 22px 55px rgba(0,0,0,.18);
  }

  .notice-title{
    font-weight:800;
    font-size:18px;
    margin-bottom:6px;
  }

  .notice-content{
    color:#6c757d;
    font-size:15px;
    margin-bottom:10px;
  }

  .notice-meta{
    font-size:13px;
    color:#868e96;
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:10px;
  }

  .badge-high{background:#e74a3b;}
  .badge-medium{background:#f6c23e;color:#212529;}
  .badge-low{background:#1cc88a;}
</style>

<!-- HEADER -->
<div class="page-header">
  <div>
    <h3><i class="bi bi-megaphone-fill"></i> Parent Notice Board</h3>
    <p class="mb-0 opacity-90">
      Important announcements from the institution
    </p>
  </div>

  <div class="student-chip">
    <i class="bi bi-person-fill"></i>
    <%= student.name %> · Roll <%= student.roll %>
  </div>
</div>

<!-- NOTICES -->
<% if (notices && notices.length > 0) { %>

  <% notices.forEach(n => { %>
    <div class="notice-card">

      <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="notice-title">
          <%= n.title %>
        </div>

        <span class="badge 
          <%= n.priority === 'high' ? 'badge-high' :
              n.priority === 'medium' ? 'badge-medium' : 'badge-low' %>">
          <%= n.priority.toUpperCase() %>
        </span>
      </div>

      <div class="notice-content">
        <%= n.content %>
      </div>

      <div class="notice-meta">
        <span>
          <i class="bi bi-building"></i>
          Admin Office
        </span>

        <span>
          <i class="bi bi-clock-fill"></i>
          <%= new Date(n.createdAt).toLocaleString() %>
        </span>
      </div>

    </div>
  <% }) %>

<% } else { %>

  <div class="alert alert-info shadow-sm">
    <i class="bi bi-info-circle-fill"></i>
    No notices available at the moment.
  </div>

<% } %>
