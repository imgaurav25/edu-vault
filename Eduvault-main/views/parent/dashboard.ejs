<% layout('parent/layouts/parentBoiler') %>
<% active = "dashboard" %>
<% title = "Parent Dashboard" %>

<style>
  body{background:#f5f7fb;}

  /* WELCOME */
  .welcome-box{
    background:linear-gradient(135deg,#6f42c1,#36b9cc);
    border-radius:22px;
    padding:28px;
    color:#fff;
    margin-bottom:32px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:16px;
  }

  .welcome-box h3{
    font-weight:900;
    margin-bottom:6px;
  }

  .student-chip{
    background:rgba(255,255,255,.2);
    padding:10px 18px;
    border-radius:30px;
    font-weight:700;
  }

  /* STAT CARDS */
  .stat-card{
    border:none;
    border-radius:20px;
    padding:24px;
    color:#fff;
    height:100%;
    box-shadow:0 14px 34px rgba(0,0,0,.15);
    transition:.3s ease;
  }

  .stat-card:hover{
    transform:translateY(-10px);
    box-shadow:0 26px 60px rgba(0,0,0,.25);
  }

  .stat-icon{
    width:54px;
    height:54px;
    border-radius:16px;
    background:rgba(255,255,255,.25);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:26px;
    margin-bottom:16px;
  }

  .stat-title{
    font-size:14px;
    opacity:.9;
    font-weight:700;
  }

  .stat-value{
    font-size:30px;
    font-weight:900;
    line-height:1.1;
  }

  .stat-sub{
    font-size:13px;
    opacity:.85;
  }

  .bg-attendance{background:linear-gradient(135deg,#1cc88a,#13855c);}
  .bg-fees-paid{background:linear-gradient(135deg,#36b9cc,#258391);}
  .bg-fees-due{background:linear-gradient(135deg,#e74a3b,#be2617);}
  .bg-performance{background:linear-gradient(135deg,#fd7e14,#c05600);}

  /* NOTICE */
  .notice-card{
    border:none;
    border-radius:18px;
    box-shadow:0 10px 30px rgba(0,0,0,.1);
  }
</style>

<!-- WELCOME -->
<div class="welcome-box">
  <div>
    <h3>Welcome, <%= parent.name %> 👋</h3>
    <p class="opacity-90 mb-0">
      Here’s an overview of your child’s academic status
    </p>
  </div>

  <div class="student-chip">
    <i class="bi bi-person-fill"></i>
    <%= student.name %> · Roll <%= student.roll %>
  </div>
</div>

<!-- STATS -->
<div class="row g-4">

  <!-- ATTENDANCE -->
  <div class="col-xl-3 col-md-6">
    <div class="stat-card bg-attendance">
      <div class="stat-icon">
        <i class="bi bi-calendar-check-fill"></i>
      </div>
      <div class="stat-title">Attendance</div>
      <div class="stat-value"><%= attendancePercent %>%</div>
      <div class="stat-sub">
        Present <%= totalPresent %> / <%= totalClasses %> classes
      </div>
    </div>
  </div>

  <!-- FEES PAID -->
  <div class="col-xl-3 col-md-6">
    <div class="stat-card bg-fees-paid">
      <div class="stat-icon">
        <i class="bi bi-cash-stack"></i>
      </div>
      <div class="stat-title">Fees Paid</div>
      <div class="stat-value">₹<%= totalPaid %></div>
      <div class="stat-sub">Successfully received</div>
    </div>
  </div>

  <!-- FEES DUE -->
  <div class="col-xl-3 col-md-6">
    <div class="stat-card bg-fees-due">
      <div class="stat-icon">
        <i class="bi bi-exclamation-circle-fill"></i>
      </div>
      <div class="stat-title">Fees Due</div>
      <div class="stat-value">₹<%= totalDue %></div>
      <div class="stat-sub">Pending payment</div>
    </div>
  </div>

  <!-- PERFORMANCE -->
  <div class="col-xl-3 col-md-6">
    <div class="stat-card bg-performance">
      <div class="stat-icon">
        <i class="bi bi-graph-up-arrow"></i>
      </div>
      <div class="stat-title">Academic Average</div>
      <div class="stat-value"><%= avgMarks %></div>
      <div class="stat-sub">Overall performance</div>
    </div>
  </div>

</div>

<!-- NOTICES -->
<div class="mt-5">
  <h4 class="fw-bold mb-3">📢 Important Notices</h4>

  <% if (notices && notices.length > 0) { %>
    <div class="list-group shadow-sm rounded-4 overflow-hidden">
      <% notices.forEach(n => { %>
        <div class="list-group-item p-4">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <h6 class="fw-bold mb-0"><%= n.title %></h6>
            <span class="badge 
              <%= n.priority === 'high' ? 'bg-danger' :
                  n.priority === 'medium' ? 'bg-warning text-dark' : 'bg-success' %>">
              <%= n.priority %>
            </span>
          </div>

          <p class="mb-1 text-muted"><%= n.content %></p>

          <small class="text-secondary">
            <i class="bi bi-clock"></i>
            <%= new Date(n.createdAt).toLocaleString() %>
          </small>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="alert alert-info">
      No notices available at the moment.
    </div>
  <% } %>
</div>
