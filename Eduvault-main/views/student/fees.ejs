<% layout('student/layouts/studentBoiler') %>
<% active = "fees" %>
<% title = "My Fees" %>

<style>
  body{background:#f5f7fb;}

  /* ===== HEADER ===== */
  .page-header{
    background:linear-gradient(135deg,#4e73df,#1cc88a);
    padding:26px;
    border-radius:18px;
    color:#fff;
    margin-bottom:30px;
  }

  .page-header h3{
    font-weight:800;
    margin-bottom:6px;
  }

  /* ===== SUMMARY CARDS ===== */
  .summary-card{
    border:none;
    border-radius:18px;
    padding:22px;
    color:#fff;
    box-shadow:0 10px 28px rgba(0,0,0,.18);
    height:100%;
  }

  .bg-total{background:linear-gradient(135deg,#6f42c1,#59339d);}
  .bg-paid{background:linear-gradient(135deg,#1cc88a,#17a673);}
  .bg-due{background:linear-gradient(135deg,#e74a3b,#be2617);}

  .summary-title{
    font-size:14px;
    opacity:.9;
    font-weight:600;
  }

  .summary-value{
    font-size:28px;
    font-weight:900;
  }

  /* ===== TABLE CARD ===== */
  .fees-card{
    background:#fff;
    border-radius:18px;
    padding:22px;
    box-shadow:0 12px 32px rgba(0,0,0,.08);
    margin-top:25px;
  }

  table th{
    background:#f8f9fc;
    font-weight:800;
    font-size:14px;
  }

  table td{
    vertical-align:middle;
    font-weight:600;
  }

  /* ===== STATUS ===== */
  .status-paid{
    background:#1cc88a;
    color:#fff;
    padding:6px 12px;
    border-radius:8px;
    font-size:13px;
    font-weight:700;
  }

  .status-due{
    background:#e74a3b;
    color:#fff;
    padding:6px 12px;
    border-radius:8px;
    font-size:13px;
    font-weight:700;
  }

  /* ===== BUTTON ===== */
  .btn-receipt{
    background:#4e73df;
    color:#fff;
    border:none;
    padding:7px 14px;
    border-radius:10px;
    font-size:13px;
    font-weight:600;
    display:inline-flex;
    align-items:center;
    gap:6px;
  }

  .btn-receipt:hover{
    background:#2e59d9;
  }
</style>

<!-- ===== HEADER ===== -->
<div class="page-header">
  <h3><i class="bi bi-cash-stack"></i> My Fees</h3>
  <p class="mb-0 opacity-90">View your payments, dues & download receipts</p>
</div>

<!-- ===== SUMMARY ===== -->
<div class="row g-4">

  <div class="col-md-4">
    <div class="summary-card bg-total">
      <div class="summary-title">Total Fee Records</div>
      <div class="summary-value"><%= fees.length %></div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="summary-card bg-paid">
      <div class="summary-title">Paid Fees</div>
      <div class="summary-value">
        ₹<%= fees
          .filter(f => (f.status || "").toLowerCase() === "paid")
          .reduce((s, f) => s + (f.amount || 0), 0)
        %>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="summary-card bg-due">
      <div class="summary-title">Pending Dues</div>
      <div class="summary-value">
        ₹<%= fees
          .filter(f => (f.status || "").toLowerCase() !== "paid")
          .reduce((s, f) => s + (f.amount || 0), 0)
        %>
      </div>
    </div>
  </div>

</div>

<!-- ===== FEES TABLE ===== -->
<div class="fees-card">
  <table class="table table-hover align-middle">
    <thead>
      <tr>
        <th>Fee Type</th>
        <th>Amount</th>
        <th>Status</th>
        <th>Date</th>
        <th>Receipt</th>
      </tr>
    </thead>

    <tbody>
      <% fees.forEach(f => { %>
      <tr>
        <td><strong><%= f.feeType || "-" %></strong></td>
        <td>₹<%= f.amount || 0 %></td>

        <td>
          <% if ((f.status || "").toLowerCase() === "paid") { %>
            <span class="status-paid">PAID</span>
          <% } else { %>
            <span class="status-due">DUE</span>
          <% } %>
        </td>

        <td>
          <%= f.date ? new Date(f.date).toLocaleDateString() : "-" %>
        </td>

        <td>
          <% if ((f.status || "").toLowerCase() === "paid" && f.paymentId) { %>
            <a href="/student/receipt/<%= f.paymentId %>" class="btn-receipt">
              <i class="bi bi-file-earmark-pdf-fill"></i>
              Download
            </a>
          <% } else { %>
            —
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
