<% layout('layouts/boilerplate') %>

<style>
  /* ===== PAGE BACKGROUND ===== */
  .role-bg {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(78,115,223,.25), transparent 40%),
      radial-gradient(circle at bottom right, rgba(28,200,138,.25), transparent 45%),
      linear-gradient(135deg, #0b214c, #061329);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  /* ===== CONTAINER ===== */
  .role-container {
    max-width: 1000px;
    width: 100%;
    text-align: center;
  }

  .role-container h1 {
    color: #ffffff;
    font-weight: 900;
    margin-bottom: 12px;
    letter-spacing: .5px;
  }

  .role-container p {
    color: rgba(255,255,255,.85);
    margin-bottom: 50px;
    font-size: 16px;
  }

  /* ===== CARD GRID ===== */
  .role-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 30px;
  }

  /* ===== ROLE CARD ===== */
  .role-card {
    background: rgba(255,255,255,.96);
    backdrop-filter: blur(14px);
    border-radius: 26px;
    padding: 38px 28px;
    box-shadow: 0 35px 90px rgba(0,0,0,.35);
    transition: all .4s ease;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
  }

  .role-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(78,115,223,.15), rgba(28,200,138,.15));
    opacity: 0;
    transition: .4s;
  }

  .role-card:hover::before {
    opacity: 1;
  }

  .role-card:hover {
    transform: translateY(-14px) scale(1.04);
    box-shadow: 0 55px 130px rgba(0,0,0,.5);
  }

  /* ===== ICON ===== */
  .role-icon {
    width: 90px;
    height: 90px;
    margin: 0 auto 22px;
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
    color: #fff;
  }

  .student { background: linear-gradient(135deg, #4e73df, #224abe); }
  .parent  { background: linear-gradient(135deg, #1cc88a, #13855c); }
  .admin   { background: linear-gradient(135deg, #f6c23e, #dda20a); }

  /* ===== TEXT ===== */
  .role-card h4 {
    font-weight: 900;
    color: #0b214c;
    margin-bottom: 6px;
  }

  .role-card span {
    font-size: 14px;
    color: #6c757d;
  }

  /* ===== FOOT NOTE ===== */
  .role-foot {
    margin-top: 40px;
    font-size: 13px;
    color: rgba(255,255,255,.75);
  }
</style>

<div class="role-bg">

  <div class="role-container">

    <h1>Welcome to EduVault</h1>
    <p>Choose your role to continue securely</p>

    <div class="role-grid">

      <!-- STUDENT -->
      <a href="/login/student" class="role-card">
        <div class="role-icon student">
          <i class="bi bi-mortarboard-fill"></i>
        </div>
        <h4>Student</h4>
        <span>Access attendance, results & notices</span>
      </a>

      <!-- PARENT -->
      <a href="/login/parent" class="role-card">
        <div class="role-icon parent">
          <i class="bi bi-people-fill"></i>
        </div>
        <h4>Parent</h4>
        <span>Track child performance & updates</span>
      </a>

      <!-- ADMIN -->
      <a href="/login/admin" class="role-card">
        <div class="role-icon admin">
          <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h4>Admin</h4>
        <span>Manage students, data & academics</span>
      </a>

    </div>

    <div class="role-foot">
      © <%= new Date().getFullYear() %> EduVault ERP · Secure · Smart · Scalable
    </div>

  </div>

</div>
