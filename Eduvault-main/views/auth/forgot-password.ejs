<% layout('layouts/boilerplate') %>

<style>
  /* ===== BACKGROUND ===== */
  .forgot-bg{
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    background:
      radial-gradient(circle at top left, rgba(78,115,223,.25), transparent 40%),
      radial-gradient(circle at bottom right, rgba(28,200,138,.25), transparent 45%),
      linear-gradient(135deg, #0b214c, #061329);
    padding:20px;
  }

  /* ===== GLASS CARD ===== */
  .forgot-card{
    width:420px;
    background:rgba(255,255,255,.95);
    backdrop-filter:blur(18px);
    border-radius:26px;
    padding:40px 34px;
    box-shadow:0 40px 90px rgba(0,0,0,.35);
    animation:fadeUp .7s ease;
  }

  @keyframes fadeUp{
    from{opacity:0;transform:translateY(25px);}
    to{opacity:1;transform:translateY(0);}
  }

  /* ===== HEADER ===== */
  .forgot-header{
    text-align:center;
    margin-bottom:28px;
  }

  .forgot-icon{
    font-size:44px;
    color:#4e73df;
    margin-bottom:8px;
  }

  .forgot-header h2{
    font-weight:900;
    color:#0b214c;
    margin-bottom:6px;
    letter-spacing:.4px;
  }

  .forgot-header p{
    font-size:14px;
    color:#6c757d;
    margin:0;
    line-height:1.5;
  }

  /* ===== INPUT ===== */
  .forgot-card label{
    font-weight:600;
    color:#212529;
    margin-bottom:6px;
  }

  .forgot-card .form-control{
    border-radius:14px;
    padding:13px 15px;
    font-size:15px;
    border:1px solid #dce1e8;
  }

  .forgot-card .form-control:focus{
    border-color:#4e73df;
    box-shadow:0 0 0 4px rgba(78,115,223,.15);
  }

  /* ===== BUTTON ===== */
  .btn-forgot{
    background:linear-gradient(135deg,#4e73df,#1cc88a);
    border:none;
    border-radius:16px;
    padding:14px;
    font-weight:800;
    letter-spacing:.4px;
    transition:.3s ease;
  }

  .btn-forgot:hover{
    transform:translateY(-2px);
    box-shadow:0 18px 40px rgba(78,115,223,.45);
  }

  /* ===== FOOT TEXT ===== */
  .forgot-note{
    text-align:center;
    margin-top:18px;
    font-size:13px;
    color:#6c757d;
  }

  .forgot-note span{
    color:#4e73df;
    font-weight:600;
  }
</style>

<div class="forgot-bg">

  <div class="forgot-card">

    <!-- HEADER -->
    <div class="forgot-header">
      <div class="forgot-icon">
        <i class="bi bi-shield-lock-fill"></i>
      </div>
      <h2>Forgot Password</h2>
      <p>
        Enter your registered email<br>
        <span>We’ll send a secure reset link</span>
      </p>
    </div>

    <!-- FORM -->
    <form action="/forgot-password" method="POST">

      <div class="mb-4">
        <label>Email Address</label>
        <input
          type="email"
          name="email"
          class="form-control"
          placeholder="example@email.com"
          required
        >
      </div>

      <button type="submit" class="btn btn-forgot w-100">
        Send Reset Link
      </button>
    </form>

    <!-- FOOT -->
    <div class="forgot-note">
      🔐 Secure • Fast • Private
    </div>

  </div>

</div>
