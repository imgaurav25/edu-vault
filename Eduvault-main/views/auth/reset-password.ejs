<% layout('layouts/boilerplate') %>

<style>
  .reset-bg{
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    background:
      radial-gradient(circle at top left, rgba(78,115,223,.25), transparent 40%),
      radial-gradient(circle at bottom right, rgba(28,200,138,.25), transparent 45%),
      linear-gradient(135deg, #0b214c, #061329);
    padding:20px;
  }

  .reset-card{
    width:420px;
    background:rgba(255,255,255,.95);
    backdrop-filter:blur(18px);
    border-radius:26px;
    padding:40px 34px;
    box-shadow:0 40px 90px rgba(0,0,0,.35);
    animation:fadeUp .7s ease;
  }

  @keyframes fadeUp{
    from{opacity:0;transform:translateY(25px);}
    to{opacity:1;transform:translateY(0);}
  }

  .reset-header{
    text-align:center;
    margin-bottom:28px;
  }

  .reset-icon{
    font-size:44px;
    color:#1cc88a;
    margin-bottom:8px;
  }

  .reset-header h2{
    font-weight:900;
    color:#0b214c;
    margin-bottom:6px;
  }

  .reset-header p{
    font-size:14px;
    color:#6c757d;
    margin:0;
  }

  .reset-card label{
    font-weight:600;
    color:#212529;
    margin-bottom:6px;
  }

  .reset-card .form-control{
    border-radius:14px;
    padding:13px 15px;
    border:1px solid #dce1e8;
  }

  .btn-reset{
    background:linear-gradient(135deg,#4e73df,#1cc88a);
    border:none;
    border-radius:16px;
    padding:14px;
    font-weight:800;
  }

  .reset-note{
    text-align:center;
    margin-top:18px;
    font-size:13px;
    color:#6c757d;
  }
</style>

<div class="reset-bg">
  <div class="reset-card">

    <div class="reset-header">
      <div class="reset-icon">
        <i class="bi bi-key-fill"></i>
      </div>
      <h2>Set New Password</h2>
      <p>Choose a strong password</p>
    </div>

    <!-- ✅ FINAL FORM -->
    <form action="/reset-password" method="POST">

      <!-- 🔑 TOKEN (DO NOT REMOVE) -->
      <input type="hidden" name="token" value="<%= token %>" />

      <div class="mb-4">
        <label>New Password</label>
        <input
          type="password"
          name="password"
          class="form-control"
          placeholder="Enter new password"
          required
        />
      </div>

      <button type="submit" class="btn btn-reset w-100">
        Update Password
      </button>
    </form>

    <div class="reset-note">
      🔒 Secure • Private • Instant Update
    </div>

  </div>
</div>
