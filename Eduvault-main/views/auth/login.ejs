<% layout('layouts/boilerplate') %>

<style>
  /* ===== LOGIN BACKGROUND ===== */
  .login-bg {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(78,115,223,.25), transparent 40%),
      radial-gradient(circle at bottom right, rgba(28,200,138,.25), transparent 45%),
      linear-gradient(135deg, #0b214c, #061329);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  /* ===== GLASS CARD ===== */
  .login-card {
    width: 420px;
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(18px);
    border-radius: 22px;
    padding: 36px 32px;
    box-shadow: 0 40px 100px rgba(0,0,0,.35);
    animation: fadeUp .7s ease;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ===== BRAND ===== */
  .login-brand {
    text-align: center;
    margin-bottom: 26px;
  }

  .login-brand h2 {
    font-weight: 900;
    color: #0b214c;
    margin-bottom: 4px;
    letter-spacing: .4px;
  }

  .login-brand p {
    font-size: 14px;
    color: #6c757d;
    margin: 0;
  }

  /* ===== FORM ===== */
  .login-card label {
    font-weight: 600;
    color: #212529;
    margin-bottom: 6px;
  }

  .login-card .form-control,
  .login-card .form-select {
    border-radius: 12px;
    padding: 12px 14px;
    font-size: 15px;
    border: 1px solid #dce1e8;
    color: #212529;
  }

  .login-card .form-control:focus,
  .login-card .form-select:focus {
    border-color: #4e73df;
    box-shadow: 0 0 0 4px rgba(78,115,223,.15);
  }

  /* ===== BUTTON ===== */
  .btn-login {
    background: linear-gradient(135deg, #4e73df, #1cc88a);
    border: none;
    border-radius: 14px;
    padding: 13px;
    font-weight: 800;
    letter-spacing: .4px;
    transition: .3s ease;
  }

  .btn-login:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(78,115,223,.45);
  }

  /* ===== FOOT LINKS ===== */
  .login-links {
    text-align: center;
    margin-top: 22px;
  }

  .login-links a {
    color: #4e73df;
    font-weight: 600;
    text-decoration: none;
  }

  .login-links a:hover {
    text-decoration: underline;
  }

  /* ===== ROLE ICON ===== */
  .role-icon {
    text-align: center;
    font-size: 38px;
    color: #4e73df;
    margin-bottom: 12px;
  }
</style>

<div class="login-bg">

  <div class="login-card">

    <!-- BRAND -->
    <div class="login-brand">
      <div class="role-icon">
        <i class="bi bi-shield-lock-fill"></i>
      </div>
      <h2>EduVault</h2>
      <p>Secure Academic Management Portal</p>
    </div>

    <!-- FORM -->
    <form action="/login" method="POST">

      <!-- ROLE -->
      <div class="mb-3">
        <label>Login As</label>
        <select name="role" class="form-select" required>
          
          <option value="student" <%= role === "student" ? "selected" : "" %>>Student</option>
      <option value="parent"  <%= role === "parent"  ? "selected" : "" %>>Parent</option>
      <option value="admin"   <%= role === "admin"   ? "selected" : "" %>>Admin</option>

        </select>
      </div>

      <!-- USER -->
      <div class="mb-3">
        <label>Email / User ID</label>
        <input
          type="text"
          name="user"
          class="form-control"
          placeholder="Enter registered email or ID"
          required
        />
      </div>

      <!-- PASSWORD -->
      <div class="mb-4">
        <label>Password</label>
        <input
          type="password"
          name="password"
          class="form-control"
          placeholder="Enter your password"
          required
        />
      </div>

      <!-- SUBMIT -->
      <button type="submit" class="btn btn-login w-100">
        Login Securely
      </button>
    </form>

    <!-- LINKS -->
    <div class="login-links">
      <a href="/forgot-password">Forgot Password?</a>

    </div>

  </div>

</div>
