<% layout('layouts/boilerplate') %>

<style>
  /* ===== BACKGROUND ===== */
  .contact-bg {
    min-height: 100vh;
    background:
      radial-gradient(circle at top right, rgba(78,115,223,.25), transparent 40%),
      radial-gradient(circle at bottom left, rgba(28,200,138,.25), transparent 45%),
      linear-gradient(135deg, #0b214c, #061329);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 15px;
  }

  /* ===== CARD ===== */
  .contact-card {
    max-width: 620px;
    width: 100%;
    background: rgba(255,255,255,.97);
    border-radius: 28px;
    padding: 44px 40px;
    box-shadow: 0 45px 120px rgba(0,0,0,.35);
    animation: fadeUp .6s ease;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(25px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ===== HEADER ===== */
  .contact-header {
    text-align: center;
    margin-bottom: 34px;
  }

  .contact-header h2 {
    font-weight: 900;
    color: #0b214c;
    margin-bottom: 8px;
  }

  .contact-header p {
    color: #6c757d;
    font-size: 15px;
    max-width: 480px;
    margin: auto;
  }

  /* ===== FORM ===== */
  .contact-card label {
    font-weight: 600;
    color: #212529;
    margin-bottom: 6px;
  }

  .contact-card .form-control {
    border-radius: 14px;
    padding: 12px 14px;
    border: 1px solid #dce1e8;
    font-size: 15px;
  }

  .contact-card .form-control:focus {
    border-color: #4e73df;
    box-shadow: 0 0 0 4px rgba(78,115,223,.15);
  }

  textarea.form-control {
    resize: none;
  }

  /* ===== BUTTON ===== */
  .contact-btn {
    background: linear-gradient(135deg, #4e73df, #1cc88a);
    border: none;
    border-radius: 16px;
    padding: 14px 28px;
    font-weight: 900;
    letter-spacing: .4px;
    color: #fff;
    transition: .3s ease;
  }

  .contact-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(78,115,223,.45);
  }

  /* ===== FOOT NOTE ===== */
  .contact-foot {
    margin-top: 26px;
    font-size: 13px;
    color: #6c757d;
    text-align: center;
  }

  .contact-foot i {
    color: #1cc88a;
  }
</style>

<div class="contact-bg">

  <div class="contact-card">

    <!-- HEADER -->
    <div class="contact-header">
      <h2>📬 Contact EduVault</h2>
      <p>
        Have a question, suggestion, or need support?  
        We’re here to listen and help you clearly.
      </p>
    </div>

    <!-- FORM (FIELDS UNCHANGED) -->
    <form action="/contact" method="POST">

      <div class="mb-3">
        <label>Full Name</label>
        <input
          type="text"
          name="fullName"
          class="form-control"
          placeholder="Enter your full name"
          required
        />
      </div>

      <div class="mb-3">
        <label>Email Address</label>
        <input
          type="email"
          name="email"
          class="form-control"
          placeholder="example@gmail.com"
          required
        />
      </div>

      <div class="mb-3">
        <label>Phone Number</label>
        <input
          type="text"
          name="phone"
          class="form-control"
          placeholder="Enter your phone number"
          required
        />
      </div>

      <div class="mb-3">
        <label>Subject</label>
        <input
          type="text"
          name="subject"
          class="form-control"
          placeholder="What is this about?"
          required
        />
      </div>

      <div class="mb-4">
        <label>Message</label>
        <textarea
          name="message"
          rows="5"
          class="form-control"
          placeholder="Write your message here..."
          required
        ></textarea>
      </div>

      <div class="text-center">
        <button class="contact-btn" type="submit">
          Send Message
        </button>
      </div>

    </form>

    <!-- FOOT -->
    <div class="contact-foot">
      <i class="bi bi-shield-lock-fill"></i>
      Your message is secure · We usually reply within 24 hours
    </div>

  </div>

</div>

<script>
function toggleTheme() {
  const root = document.documentElement;
  const btn = document.getElementById("themeToggleBtn");

  const isLight = root.dataset.theme === "light";
  root.dataset.theme = isLight ? "dark" : "light";

  btn.textContent = isLight ? "🌙" : "☀️";
  localStorage.setItem("theme", root.dataset.theme);
}

document.addEventListener("DOMContentLoaded", () => {
  const root = document.documentElement;
  const btn = document.getElementById("themeToggleBtn");

  const savedTheme = localStorage.getItem("theme") || "light";
  root.dataset.theme = savedTheme;

  if (btn) {
    btn.textContent = savedTheme === "light" ? "☀️" : "🌙";
  }
});
</script>

