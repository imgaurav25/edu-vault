<% layout('layouts/boilerplate') %>

<style>
  /* ===== PAGE BACKGROUND ===== */
  .pay-bg {
    min-height: 100vh;
    background:
      radial-gradient(circle at top right, rgba(78,115,223,.25), transparent 40%),
      radial-gradient(circle at bottom left, rgba(28,200,138,.25), transparent 45%),
      linear-gradient(135deg, #0b214c, #061329);
    padding: 60px 15px;
  }

  /* ===== CARD ===== */
  .pay-card {
    max-width: 520px;
    margin: auto;
    background: rgba(255,255,255,.97);
    border-radius: 26px;
    padding: 36px 34px;
    box-shadow: 0 45px 120px rgba(0,0,0,.35);
    animation: fadeUp .6s ease;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(25px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ===== HEADER ===== */
  .pay-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .pay-header h1 {
    font-weight: 900;
    color: #0b214c;
    margin-bottom: 6px;
  }

  .pay-header p {
    color: #6c757d;
    font-size: 15px;
  }

  /* ===== INPUTS ===== */
  .pay-card label {
    font-weight: 600;
    color: #212529;
    margin-bottom: 6px;
  }

  .pay-card .form-control,
  .pay-card .form-select {
    border-radius: 14px;
    padding: 12px 14px;
    border: 1px solid #dce1e8;
    font-size: 15px;
  }

  .pay-card .form-control:focus,
  .pay-card .form-select:focus {
    border-color: #4e73df;
    box-shadow: 0 0 0 4px rgba(78,115,223,.15);
  }

  /* ===== PAY BUTTON ===== */
  .pay-btn {
    background: linear-gradient(135deg, #4e73df, #1cc88a);
    border: none;
    border-radius: 16px;
    padding: 14px;
    font-weight: 900;
    letter-spacing: .4px;
    color: #fff;
    transition: .3s ease;
  }

  .pay-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(78,115,223,.45);
  }

  /* ===== TRUST ===== */
  .pay-trust {
    text-align: center;
    margin-top: 26px;
    font-size: 13px;
    color: #6c757d;
  }

  .pay-trust i {
    color: #1cc88a;
  }
</style>

<div class="pay-bg">

  <div class="pay-card">

    <!-- HEADER -->
    <div class="pay-header">
      <h1>Secure Payment</h1>
      <p>Pay your fees safely using Razorpay</p>
    </div>

    <!-- FORM (UNCHANGED FIELDS) -->
    <form id="paymentForm">

      <div class="mb-3">
        <label>Student ID</label>
        <input type="text" id="studentId" class="form-control" placeholder="Enter Student ID" required>
      </div>

      <div class="mb-3">
        <label>Full Name</label>
        <input type="text" id="studentName" class="form-control" placeholder="Student Full Name" required>
      </div>

      <div class="mb-3">
        <label>Email Address</label>
        <input type="email" id="studentEmail" class="form-control" placeholder="Email Address" required>
      </div>

      <div class="mb-3">
        <label>Phone Number</label>
        <input type="text" id="studentPhone" class="form-control" placeholder="Phone Number" required>
      </div>

      <div class="mb-3">
        <label>Fee Type</label>
        <select id="feeType" class="form-select" required>
          <option value="">Select Fee Type</option>
          <option value="semester">Semester Fee</option>
          <option value="hostel">Hostel Fee</option>
          <option value="library">Library Fine</option>
        </select>
      </div>

      <div class="mb-4">
        <label>Amount (₹)</label>
        <input type="number" id="amount" class="form-control" placeholder="Enter Amount" required>
      </div>

      <button type="button" id="payBtn" class="pay-btn w-100">
        Pay Securely ₹
      </button>

    </form>

    <!-- TRUST -->
    <div class="pay-trust">
      <i class="bi bi-shield-lock-fill"></i>
      100% Secure · Encrypted · Powered by Razorpay
    </div>

  </div>

</div>

<!-- RAZORPAY -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
document.getElementById("payBtn").onclick = async function () {

  let studentId = document.getElementById("studentId").value;
  let studentName = document.getElementById("studentName").value;
  let studentEmail = document.getElementById("studentEmail").value;
  let studentPhone = document.getElementById("studentPhone").value;
  let feeType = document.getElementById("feeType").value;
  let amount = document.getElementById("amount").value;

  if (!studentId || !studentName || !studentEmail || !studentPhone || !feeType || !amount) {
    return alert("⚠ Please fill all fields before payment!");
  }

  const res = await fetch("/create-order", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ amount })
  });

  const data = await res.json();
  if (!data.success) return alert("❌ Razorpay order creation failed!");

  var options = {
    key: "<%= process.env.RAZORPAY_KEY_ID %>",
    amount: data.order.amount,
    currency: "INR",
    name: "EduVault ERP",
    description: feeType + " Payment",
    order_id: data.order.id,

    handler: async function (response) {
      const result = await fetch("/payment-success", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          razorpay_payment_id: response.razorpay_payment_id,
          razorpay_order_id: response.razorpay_order_id,
          razorpay_signature: response.razorpay_signature,
          studentId,
          studentName,
          studentEmail,
          studentPhone,
          feeType,
          amount: Number(amount)
        })
      });

      const resData = await result.json();
      alert(resData.message);
    },

    prefill: { name: studentName, email: studentEmail, contact: studentPhone },
    theme: { color: "#1e40af" }
  };

  var rzp = new Razorpay(options);
  rzp.open();
};
</script>



<!-- 
//for dark and light theme  -->
<script>
function toggleTheme() {
  const root = document.documentElement;
  const btn = document.getElementById("themeToggleBtn");

  const isLight = root.dataset.theme === "light";
  root.dataset.theme = isLight ? "dark" : "light";

  btn.textContent = isLight ? "🌙" : "☀️";
  localStorage.setItem("theme", root.dataset.theme);
}

document.addEventListener("DOMContentLoaded", () => {
  const root = document.documentElement;
  const btn = document.getElementById("themeToggleBtn");

  const savedTheme = localStorage.getItem("theme") || "light";
  root.dataset.theme = savedTheme;

  if (btn) {
    btn.textContent = savedTheme === "light" ? "☀️" : "🌙";
  }
});
</script>
