        <div class="feature-icon">📋</div>
        <h5 class="fw-bold">Attendance Management</h5>
        <p>
          Subject-wise and monthly attendance tracking with automated
          percentage calculation and reports.
        </p>
      </div>
    </div>

    <!-- FEES -->
