      <div class="card feature-card p-4 text-center">
        <div class="feature-icon">💳</div>
        <h5 class="fw-bold">Fee Management</h5>
        <p>
          Online fee collection, payment history, due tracking,
          receipts, and financial transparency.
        </p>
      </div>
    </div>

    <!-- RESULTS -->
    <div class="col-md-4">
      <div class="card feature-card p-4 text-center">
        <div class="feature-icon">📊</div>
        <h5 class="fw-bold">Exam & Result System</h5>
        <p>
          Result publication, subject-wise marks, CGPA calculation,
          rank generation, and analytics.
        </p>
      </div>
    </div>

    <!-- AI PERFORMANCE -->
    <div class="col-md-4">
      <div class="card feature-card p-4 text-center">
        <div class="feature-icon">🤖</div>
        <h5 class="fw-bold">AI-Based Performance Analysis</h5>
        <p>
          AI-driven insights to analyze attendance, marks, and trends
          to predict student performance.
        </p>
      </div>
    </div>

    <!-- HOSTEL -->
    <div class="col-md-4">
      <div class="card feature-card p-4 text-center">
        <div class="feature-icon">🏠</div>
        <h5 class="fw-bold">Hostel Management</h5>
        <p>
          Hostel allocation, room details, attendance, and
          fee tracking for residential students.
        </p>
      </div>
    </div>

    <!-- LIBRARY -->
    <div class="col-md-4">
      <div class="card feature-card p-4 text-center">
        <div class="feature-icon">📚</div>
        <h5 class="fw-bold">Library Management</h5>
        <p>
          Book inventory, issue/return system, fines,
          and digital library access.
        </p>
      </div>
    </div>

    <!-- REPORTS -->
    <div class="col-md-4">
      <div class="card feature-card p-4 text-center">
        <div class="feature-icon">📅</div>
        <h5 class="fw-bold">Monthly Academic Reports</h5>
        <p>
          End-of-month attendance, performance, and progress
          reports for students and faculty.
        </p>
      </div>
    </div>

    <!-- ADMIN CONTROL -->
    <div class="col-md-4">
      <div class="card feature-card p-4 text-center">
        <div class="feature-icon">🛡️</div>
        <h5 class="fw-bold">Admin & Security Control</h5>
        <p>
          Role-based access, secure authentication,
          and complete administrative control.
        </p>
      </div>
    </div>

  </div>
</section>

<!-- FOOT NOTE -->
<section class="text-center py-4 bg-light">
  <p class="mb-0 text-muted">
    Built for scalability • Secure • Optimized for Engineering Institutions
  </p>
</section>




<!-- for dark and light theme  -->
 <script>
function toggleTheme() {
  const root = document.documentElement;
  const btn = document.getElementById("themeToggleBtn");

  const isLight = root.dataset.theme === "light";
  root.dataset.theme = isLight ? "dark" : "light";

  btn.textContent = isLight ? "🌙" : "☀️";
  localStorage.setItem("theme", root.dataset.theme);
}

document.addEventListener("DOMContentLoaded", () => {
  const root = document.documentElement;
  const btn = document.getElementById("themeToggleBtn");

  const savedTheme = localStorage.getItem("theme") || "light";
  root.dataset.theme = savedTheme;

  if (btn) {
    btn.textContent = savedTheme === "light" ? "☀️" : "🌙";
  }
});
</script>

