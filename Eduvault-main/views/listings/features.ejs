<% layout('layouts/boilerplate') %>

<style>
  .features-hero {
    background: linear-gradient(135deg, #4e73df, #1cc88a);
    color: white;
    padding: 70px 20px;
    border-radius: 0 0 40px 40px;
  }

  .feature-card {
    border: none;
    border-radius: 18px;
    transition: all 0.25s ease;
    background: #ffffff;
    height: 100%;
  }

  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.12);
  }

  .feature-icon {
    font-size: 42px;
    margin-bottom: 15px;
    color: #4e73df;
  }

  .section-title {
    font-weight: 800;
    color: #2e2e2e;
  }

  .section-subtitle {
    color: #6c757d;
    max-width: 700px;
    margin: auto;
  }

  .badge-soft {
    background: rgba(78,115,223,0.1);
    color: #4e73df;
    font-weight: 600;
    border-radius: 12px;
    padding: 6px 14px;
    font-size: 13px;
  }
</style>

