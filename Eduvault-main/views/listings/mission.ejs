<%- layout('layouts/boilerplate') %>

<style>
/* ================= THEME VARIABLES ================= */
:root {
  --bg: #030712;
  --bg-soft: #0b214c;
  --text: #ffffff;
  --text-strong: #f9fbff;
  --text-soft: rgba(235,240,255,0.88);
  --primary: #6aa3ff;
  --glass: rgba(255,255,255,0.10);
  --border: rgba(255,255,255,0.22);
}

[data-theme="light"] {
  --bg: #f5f7fb;
  --bg-soft: #e6edff;
  --text: #0b214c;
  --text-strong: #061329;
  --text-soft: #3b3b3b;
  --glass: rgba(255,255,255,0.8);
  --border: rgba(0,0,0,0.08);
}

/* ================= BASE ================= */
body {
  background: radial-gradient(circle at top, var(--bg-soft), var(--bg));
  color: var(--text);
  font-family: system-ui, -apple-system, Segoe UI, Roboto;
}

/* ================= HERO ================= */
/* Padding accounts for fixed navbar height */
.hero {
  padding: 110px 20px 90px;
  text-align: center;
}

.hero h1 {
  font-size: clamp(40px, 5.5vw, 64px);
  font-weight: 900;
  letter-spacing: -1.1px;
  color: var(--text-strong);
}

.hero p {
  max-width: 820px;
  margin: 22px auto 0;
  font-size: 19px;
  line-height: 1.7;
  color: var(--text-soft);
}

/* ================= CONTAINER ================= */
.container {
  max-width: 1200px;
}

/* ================= GLASS CARD ================= */
.card {
  background: var(--glass);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 42px;
  backdrop-filter: blur(16px);
  margin-bottom: 50px;

  opacity: 0;
  transform: translateY(40px);
  transition: all .8s ease;
}

.card.show {
  opacity: 1;
  transform: translateY(0);
}

.card h2 {
  font-size: 32px;
  margin-bottom: 18px;
  font-weight: 800;
  background: linear-gradient(90deg, var(--text-strong), var(--primary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.card p {
  font-size: 18px;
  line-height: 1.75;
  color: var(--text-soft);
}

/* ================= GRID ================= */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px,1fr));
  gap: 24px;
  margin-top: 28px;
}

.grid div {
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 22px;
  font-size: 16.5px;
  color: var(--text-strong);
}

.grid strong {
  display: block;
  margin-bottom: 6px;
  font-size: 17px;
}

/* ================= HIGHLIGHT ================= */
.highlight {
  margin-top: 26px;
  font-size: 20px;
  font-weight: 700;
  color: var(--text-strong);
}

/* ================= MOBILE ================= */
@media (max-width: 768px) {
  .hero {
    padding: 95px 16px 75px;
  }

  .card {
    padding: 30px;
  }

  .hero h1 {
    font-size: 38px;
  }

  .hero p {
    font-size: 17px;
  }
}
</style>

<!-- ================= HERO ================= -->
<section class="hero">
  <h1>Building the Digital Core of Education</h1>
  <p>
    EduVault is engineering a future where education runs on intelligence,
    automation, and trust — not paperwork or fragmented systems.
  </p>
</section>

<div class="container my-5">

  <!-- WHY -->
  <div class="card animate">
    <h2>Why EduVault Exists</h2>
    <p>
      Institutions struggle with disconnected tools, manual workflows,
      and unclear data. EduVault replaces that complexity with a single,
      intelligent operating system built for clarity and scale.
    </p>

    <div class="grid">
      <div><strong>Administrators</strong>Strategic visibility & control</div>
      <div><strong>Educators</strong>Effortless academic workflows</div>
      <div><strong>Students</strong>Modern, frictionless experience</div>
      <div><strong>Parents</strong>Real-time transparency & trust</div>
    </div>
  </div>

  <!-- AI VISION -->
  <div class="card animate">
    <h2>Our AI-Driven Vision</h2>
    <p>
      EduVault continuously learns from institutional data to
      predict risks, optimize outcomes, and empower decision-makers.
    </p>

    <div class="grid">
      <div>AI attendance & dropout risk prediction</div>
      <div>Performance intelligence & alerts</div>
      <div>Automated fee & compliance workflows</div>
      <div>Leadership decision dashboards</div>
    </div>

    <div class="highlight">
      Intelligence that works quietly — but powerfully.
    </div>
  </div>

  <!-- INVESTOR -->
  <div class="card animate">
    <h2>Built for Scale. Trusted by Design.</h2>
    <p>
      Our platform is cloud-native, security-first, and engineered
      to support institutions from a single campus to global networks.
    </p>

    <div class="grid">
      <div>Enterprise-grade security architecture</div>
      <div>API-first & modular design</div>
      <div>Multi-institution scalability</div>
      <div>Data governance & compliance ready</div>
    </div>
  </div>

  <!-- FUTURE -->
  <div class="card animate">
    <h2>Our Long-Term Mission</h2>
    <p>
      To become the trusted digital backbone of modern education —
      powering institutions worldwide with clarity, intelligence,
      and human-centered design.
    </p>

    <div class="highlight">
      One platform. One source of truth. Infinite impact.
    </div>
  </div>

</div>

<script>
/* Scroll reveal animation */
const cards = document.querySelectorAll(".animate");
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add("show");
    }
  });
}, { threshold: 0.15 });

cards.forEach(card => observer.observe(card));
</script>




<script>
function toggleTheme() {
  const root = document.documentElement;
  const btn = document.getElementById("themeToggleBtn");

  const isLight = root.dataset.theme === "light";
  root.dataset.theme = isLight ? "dark" : "light";

  btn.textContent = isLight ? "🌙" : "☀️";
  localStorage.setItem("theme", root.dataset.theme);
}

document.addEventListener("DOMContentLoaded", () => {
  const root = document.documentElement;
  const btn = document.getElementById("themeToggleBtn");

  const savedTheme = localStorage.getItem("theme") || "light";
  root.dataset.theme = savedTheme;

  if (btn) {
    btn.textContent = savedTheme === "light" ? "☀️" : "🌙";
  }
});
</script>
